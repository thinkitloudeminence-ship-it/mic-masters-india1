PORT=5000
NODE_ENV=production

# MongoDB Atlas connection string
MONGODB_URI=your_mongodb_connection_string_here

# Comma-separated list of frontend domains allowed to call this API
# e.g. https://www.micmastersindia.com,https://micmastersindia.com
ALLOWED_ORIGINS=https://www.micmastersindia.com,https://micmastersindia.com

# Random long secret used to sign admin JWT sessions
# Generate one with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=replace_with_a_long_random_string

# Used ONLY by seedAdmin.js to create/reset the admin login (run once, then
# you can remove ADMIN_PASSWORD from this file if you want)
ADMIN_USERNAME=your_admin_username
ADMIN_PASSWORD=choose_a_strong_password_min_8_chars

# Cloudinary (for storing payment screenshots reliably)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Gmail SMTP for sending the "registration confirmed" email
# Use a Gmail App Password (not your normal Gmail password):
# https://myaccount.google.com/apppasswords
EMAIL_USER=youraddress@gmail.com
EMAIL_APP_PASSWORD=your_16_char_app_password
